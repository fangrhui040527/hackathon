# ── Azure OpenAI (REQUIRED for agent analysis) ──────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ── Azure Content Understanding (OPTIONAL — set to enable image analysis) ─
# Without this, use --manual-json to provide food data directly.
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_CONTENT_UNDERSTANDING_KEY=your-content-understanding-key
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=food-analyzer

# ── Azure Blob Storage (OPTIONAL — knowledge DBs fall back to local JSON files) ─
# Without this, knowledge databases load from knowledge_json/ folder automatically.
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER_NAME=food-analysis
# AZURE_KNOWLEDGE_CONTAINER_NAME=healthlens

# ── USDA FoodData Central API (OPTIONAL — uses DEMO_KEY by default) ──────
# Free key: https://fdc.nal.usda.gov/api-key-signup
# USDA_API_KEY=DEMO_KEY
