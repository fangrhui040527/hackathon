# ── Azure AI Foundry (REQUIRED) ─────────────────────────────────────────
AZURE_AI_FOUNDRY_ENDPOINT=https://YOUR-RESOURCE.services.ai.azure.com/api/projects/YOUR-PROJECT

# ── Azure Content Understanding (OPTIONAL — enables food label image analysis) ─
# Without this, the server sends raw data to agents for best-effort analysis.
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/
AZURE_CONTENT_UNDERSTANDING_KEY=your-content-understanding-key
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=HealthLens

# ── Server ──────────────────────────────────────────────────────────────
# PORT=8000
